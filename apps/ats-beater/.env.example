# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ats_beater_dev

# AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_FLASH_MODEL=gemini-3-flash-preview
GEMINI_PRO_MODEL=gemini-3.1-pro-preview

# JWT (issued by this service after Supabase auth validates the user)
JWT_SECRET=your-jwt-secret-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Supabase (primary auth + is_pro check for Ocupa integration)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Credits (free tier — bypassed for is_pro users)
DAILY_FREE_CREDITS=3

# Storage (not wired yet — leave empty)
GCS_BUCKET=
GCS_CREDENTIALS_PATH=

# LaTeX (set automatically in Docker: /usr/bin)
LATEX_BIN_PATH=/usr/bin

# App
ENVIRONMENT=DEV
FRONTEND_URL=http://localhost:8000
DEV_AUTH_BYPASS=false

# Legacy Google OAuth (kept for backward compat — not needed for Ocupa)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Legacy Razorpay (not used for is_pro users — keep empty)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
